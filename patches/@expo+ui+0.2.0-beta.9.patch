+private extension View {
+  // On macOS a bare `Form` uses the plain columns style and only takes its
+  // intrinsic size, so it renders cramped in the top-leading corner of the host.
+  // Use the grouped (inset) style and fill the host to match the modern macOS look.
+  // iOS/tvOS are left untouched.
+  @ViewBuilder
+  func applyExpoUIFormStyle() -> some View {
+#if os(macOS)
+    if #available(macOS 13.0, *) {
+      self
+        .formStyle(.grouped)
+        .frame(maxWidth: .infinity, maxHeight: .infinity)
+    } else {
+      self
+    }
+#else
+    self
+#endif
+  }
+}
